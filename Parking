#include <iostream>
#include <algorithm>
#include <vector>

using namespace std;

void solve()
{
    int n;
    cin >> n;

    int maxPos = -1000;
    int minPos = 1000;

    for (int i = 0; i < n; i++)
    {
        int x;
        cin >> x;

        maxPos = max(maxPos, x);
        minPos = min(minPos, x);
    }

    int totalDist = (maxPos - minPos) * 2;
    cout << totalDist << endl;
}

int main()
{
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;

    while (t--)
        solve();

    return 0;
}
